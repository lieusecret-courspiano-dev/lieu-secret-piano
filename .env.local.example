# ══════════════════════════════════════════════════════
# LIEU SECRET V3 — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ══════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici

# ── Resend (emails) ───────────────────────────────────
# Créez un compte sur resend.com et générez une clé API
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Stripe (paiements) ────────────────────────────────
# Trouvez ces valeurs dans : Stripe → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Admin ─────────────────────────────────────────────
# Identifiants pour accéder à /admin
ADMIN_EMAIL=admin@lieusecret-courspiano.fr
ADMIN_PASSWORD=votre_mot_de_passe_securise

# ── Application ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://lieusecret-courspiano.fr

# ── Email expéditeur ──────────────────────────────────
# L'email depuis lequel les confirmations sont envoyées
# Doit être vérifié dans Resend
ADMIN_EMAIL_FROM=contact@lieusecret-courspiano.fr